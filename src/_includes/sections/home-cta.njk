{# Dummy CTA — redo later #}
<section class="section-padding" id="contact" style="background: #f1f5f9;">
  <div class="container-custom">
    {% set c = home.cta if home and home.cta else {} %}
    <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem;">{{ c.title | default('Get in touch') }}</h2>
    <p style="margin-bottom: 1rem;">{{ c.description | default('Ready to start? Reach out.') }}</p>
    {% if c.button and c.button.label %}
    <a href="{{ c.button.url }}" style="display: inline-block; padding: 0.5rem 1rem; background: #2563eb; color: white; text-decoration: none; border-radius: 4px;">{{ c.button.label }}</a>
    {% endif %}
  </div>
</section>
