{# The space — centered heading; 4 cards with bg image, title, bottom overlay + text #}
<section class="section-padding bg-page" id="the-space">
  <div class="container-custom">
    {% set s = home.theSpace if home and home.theSpace else {} %}
    {% set spaceTitle1 = s.headingLine1 | default('Take a look inside') %}
    {% set spaceTitle2 = s.headingLine2 | default('your new favourite workspace') %}
    <div class="text-center">
      <h2 class="mx-auto max-w-2xl text-3xl font-black leading-tight text-gray-900 md:text-4xl lg:text-5xl">
        {{- spaceTitle1 }} <br class="md:hidden" aria-hidden="true" />{{ spaceTitle2 -}}
      </h2>
    </div>

    <div class="mt-12 md:mt-16 max-sm:-mx-4 max-sm:px-4">
      <div class="the-space-cards-row flex max-sm:flex-nowrap max-sm:gap-5 max-sm:overflow-x-auto max-sm:overflow-y-visible max-sm:pb-3 sm:grid sm:grid-cols-2 sm:gap-6 sm:overflow-visible sm:pb-0 md:gap-8 lg:grid-cols-4 [-webkit-overflow-scrolling:touch]">
      {% for card in (s.cards or []) %}
      {% set cardImg = card.image | default("/assets/images/the-space-default.png") %}
      {% set galleryImgs = card.gallery if card.gallery and (card.gallery | length) else [cardImg] %}
      {% set titlePlain = (card.title | default("")) | replace("\n", " ") %}
      <article
        class="max-sm:max-w-[260px] max-sm:w-[min(260px,82vw)] max-sm:shrink-0 group relative min-h-[320px] overflow-hidden rounded-lg bg-gray-200 bg-cover bg-center sm:max-w-none sm:w-auto md:min-h-[380px]"
        style="background-image: url('{{ cardImg | url }}');"
      >
        <button
          type="button"
          data-space-gallery-trigger
          data-gallery-images="{% for img in galleryImgs %}{{ img | url }}{% if not loop.last %}|{% endif %}{% endfor %}"
          data-gallery-title="{{ titlePlain | escape }}"
          class="absolute inset-0 z-10 cursor-pointer border-0 bg-transparent p-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black/40"
          aria-label="View photos: {{ titlePlain | escape }}"
        >
          <span class="pointer-events-none absolute inset-0 bg-black/0 transition-colors group-hover:bg-black/10 group-focus-within:bg-black/15" aria-hidden="true"></span>
        </button>
        <h3 class="pointer-events-none relative z-0 p-[1em] text-md font-bold tracking-wider text-white uppercase [text-shadow:0_1px_3px_rgba(0,0,0,0.8)]">{{ (card.title | default("")) | replace("\n", "<br>") | safe }}</h3>
        <div class="pointer-events-none absolute bottom-0 left-0 right-0 z-0 flex min-h-[50%] flex-col justify-end bg-gradient-to-t from-black/100 via-black/50 to-transparent p-[1em]">
          <p class="text-sm leading-relaxed text-white md:text-md">{{ card.description }}</p>
        </div>
      </article>
      {% endfor %}
      </div>
    </div>
  </div>
</section>
