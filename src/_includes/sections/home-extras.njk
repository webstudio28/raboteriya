{# Extras — centered heading + intro; moving strip of squares (icon 120px + title); CTA like about #}
<section class="section-padding bg-page" id="extras">
  <div class="container-custom">
    {% set e = home.extras if home and home.extras else {} %}
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black leading-tight text-gray-900">{{ e.heading | default('... and a few more extras') }}</h2>
      <p class="mt-6 md:mt-8 max-w-2xl mx-auto text-lg text-gray-900">{{ e.paragraph | default('') }}</p>
    </div>
  </div>

  <div class="extras-strip-wrapper mt-12 md:mt-16 pb-8 md:pb-12">
    <div class="extras-strip" aria-hidden="true">
      <div class="extras-strip-set">
        {% for item in (e.items or []) %}
        <div class="rounded-xl border border-gray-200 bg-white shadow-xl p-6 flex flex-col items-center text-center w-[200px] flex-shrink-0">
          <img src="{{ item.icon | default('/assets/images/extras-default-icon.png') }}" alt="" class="w-[120px] h-[120px] object-contain flex-shrink-0" loading="lazy" />
          <p class="mt-4 text-base text-gray-900 font-medium">{{ item.title }}</p>
        </div>
        {% endfor %}
      </div>
      <div class="extras-strip-set">
        {% for item in (e.items or []) %}
        <div class="rounded-xl border border-gray-200 bg-white shadow-xl p-6 flex flex-col items-center text-center w-[200px] flex-shrink-0">
          <img src="{{ item.icon | default('/assets/images/extras-default-icon.png') }}" alt="" class="w-[120px] h-[120px] object-contain flex-shrink-0" loading="lazy" />
          <p class="mt-4 text-base text-gray-900 font-medium">{{ item.title }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% if e.cta and e.cta.label %}
  <div class="container-custom mt-12 md:mt-16 text-center">
    <a href="{{ e.cta.url }}" class="inline-block px-5 py-2.5 lg:px-6 lg:py-3 lg:text-lg rounded-xl bg-transparent text-gray-900 font-extrabold border-[3px] border-gray-900 hover:bg-gray-900 hover:text-white transition-colors">{{ e.cta.label }}</a>
  </div>
  {% endif %}
</section>
