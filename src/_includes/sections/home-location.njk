{# Location — centered copy; map aligned to container, shorter height #}
<section class="section-padding bg-page" id="location">
  <div class="container-custom text-center">
    {% set loc = home.location if home and home.location else {} %}

    <h2 class="text-4xl md:text-5xl font-black tracking-tight text-gray-900">
      {{ loc.heading | default('Location') }}
    </h2>
    {% if loc.address %}
    <p class="mt-4 mx-auto max-w-3xl text-base md:text-lg text-gray-900 font-medium">{{ loc.address }}</p>
    {% endif %}
    {% if loc.directions %}
    <p class="mt-3 mx-auto max-w-3xl text-base md:text-lg text-gray-700">{{ loc.directions }}</p>
    {% endif %}

    {% if loc.mapEmbedUrl %}
    <div class="relative mt-8 md:mt-10 aspect-[2/1] w-full overflow-hidden rounded-2xl border border-gray-200 shadow-lg md:aspect-[3/1]">
      <iframe
        src="{{ loc.mapEmbedUrl }}"
        class="absolute inset-0 h-full w-full"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="{{ loc.mapTitle | default('Raboteriya on Google Maps') }}"
      ></iframe>
    </div>
    {% endif %}
  </div>
</section>
