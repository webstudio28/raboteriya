{# Memberships — soft gradient section; premium card has a subtle warm gradient #}
<section class="memberships-section section-padding" id="memberships">
  <div class="container-custom">
    {% set m = home.memberships if home and home.memberships else {} %}
    <div class="text-center">
      <h2 class="text-3xl font-black leading-tight text-white md:text-4xl lg:text-5xl">{{ m.heading | default('Memberships, Day Passes & Pricing') }}</h2>
      <p class="mt-6 max-w-2xl mx-auto text-lg text-white md:mt-8">{{ m.paragraph | default('') }}</p>
    </div>

    <div class="mt-12 md:mt-16 max-sm:-mx-4 max-sm:px-4">
      <div class="memberships-cards-row flex max-sm:flex-nowrap max-sm:items-stretch max-sm:gap-5 max-sm:overflow-x-auto max-sm:overflow-y-visible max-sm:pb-3 [-webkit-overflow-scrolling:touch] sm:grid sm:grid-cols-2 sm:items-center sm:gap-6 sm:overflow-visible sm:pb-0 md:gap-8 lg:grid-cols-4">
      {% for card in (m.cards or []) %}
      <article class="memberships-card flex flex-col max-sm:w-[min(280px,88vw)] max-sm:max-w-[280px] max-sm:shrink-0 rounded-xl border border-gray-200 p-6 text-gray-900 shadow-xl transition-transform duration-300 hover:scale-[1.02] sm:max-w-none sm:w-auto {{ 'memberships-card--featured min-h-[380px] max-sm:order-first max-sm:scale-100 sm:order-none sm:scale-105 border-2 shadow-2xl relative z-10' if card.featured else 'min-h-[360px]' }}">
        <h3 class="text-base font-bold uppercase tracking-wider text-gray-900">{{ card.title | default('') }}</h3>
        <p class="mt-8 text-lg font-semibold text-gray-900">{{ card.price | default('') }}</p>
        <hr class="mb-4 mt-3 border-gray-200" />
        <ul class="m-0 mt-auto flex list-none flex-col-reverse gap-2 p-0 text-sm text-gray-700">
          {% if card.showAsExcluded and (card.excludedInclusions or []) | length %}
          {% for item in (card.excludedInclusions or []) %}
          <li class="flex items-start gap-2">
            <span class="mt-0.5 flex-shrink-0 text-red-600" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </span>
            <span>{{ item }}</span>
          </li>
          {% endfor %}
          {% endif %}
          {% for item in (card.inclusions or []) %}
          <li class="flex items-start gap-2">
            <span class="mt-0.5 flex-shrink-0 text-emerald-600" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M11.5 3.5L5.25 9.75L2.5 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span>{{ item }}</span>
          </li>
          {% endfor %}
        </ul>
      </article>
      {% endfor %}
      </div>
    </div>
  </div>
</section>
