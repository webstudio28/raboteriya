{# Memberships — same layout as The space; cards like extras (border, radius, shadow); text-only: h3, price, line, inclusions with checkmark (list bottom-to-top) #}
<section class="section-padding bg-page" id="memberships">
  <div class="container-custom">
    {% set m = home.memberships if home and home.memberships else {} %}
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black leading-tight text-gray-900">{{ m.heading | default('Memberships, Day Passes & Pricing') }}</h2>
      <p class="mt-6 md:mt-8 max-w-2xl mx-auto text-lg text-gray-900">{{ m.paragraph | default('') }}</p>
    </div>

    <div class="mt-12 md:mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 items-center">
      {% for card in (m.cards or []) %}
      <article class="rounded-xl border p-6 flex flex-col transition-transform duration-300 hover:scale-[1.02] {{ 'min-h-[380px] scale-105 bg-gray-900 border-2 border-gray-900 shadow-2xl ring-2 ring-gray-900/10 relative z-10' if card.featured else 'min-h-[360px] bg-white border border-brown-300 shadow-xl' }}">
        <h3 class="text-base font-bold tracking-wider uppercase {{ 'text-white' if card.featured else 'text-gray-900' }}">{{ card.title | default('') }}</h3>
        <p class="mt-8 text-lg font-semibold {{ 'text-white' if card.featured else 'text-gray-900' }}">{{ card.price | default('') }}</p>
        <hr class="mt-3 mb-4 {{ 'border-white/30' if card.featured else 'border-gray-200' }}" />
        <ul class="flex flex-col-reverse gap-2 mt-auto text-sm list-none p-0 m-0 {{ 'text-gray-200' if card.featured else 'text-gray-700' }}">
          {% if card.showAsExcluded and (card.excludedInclusions or []) | length %}
          {% for item in (card.excludedInclusions or []) %}
          <li class="flex items-start gap-2">
            <span class="flex-shrink-0 mt-0.5 text-red-500" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </span>
            <span>{{ item }}</span>
          </li>
          {% endfor %}
          {% endif %}
          {% for item in (card.inclusions or []) %}
          <li class="flex items-start gap-2">
            <span class="flex-shrink-0 mt-0.5 {{ 'text-white' if card.featured else 'text-emerald-600' }}" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M11.5 3.5L5.25 9.75L2.5 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span>{{ item }}</span>
          </li>
          {% endfor %}
        </ul>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
