{# Contact — two-column: left info, right form + socials #}
<section class="section-padding bg-page" id="contact">
  <div class="container-custom">
    {% set c = home.contact if home and home.contact else {} %}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20">

      {# ── Left column ── #}
      <div class="flex flex-col">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 leading-tight">
          {{ c.heading | default('Ready to join us?') }}
        </h2>

        <p class="mt-6 text-base md:text-lg text-gray-700 whitespace-pre-line leading-relaxed">{{ c.description | default("Give us a call or fill out the enquiry form.\nWe'll get back to you as soon as possible.") }}</p>

        {% if c.note %}
        <p class="mt-6 text-base md:text-lg text-gray-700 leading-relaxed">{{ c.note }}</p>
        {% endif %}

        <div class="mt-auto pt-12 space-y-5">
          {% if c.email %}
          <div class="flex items-center gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-gray-900 text-white flex items-center justify-center">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <div>
              <p class="text-xs text-gray-500 font-medium tracking-wide">E-mail</p>
              <a href="mailto:{{ c.email }}" class="text-base font-medium text-gray-900 hover:text-brand-primary">{{ c.email }}</a>
            </div>
          </div>
          {% endif %}

          {% if c.phone %}
          <div class="flex items-center gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-gray-900 text-white flex items-center justify-center">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <div>
              <p class="text-xs text-gray-500 font-medium tracking-wide">Phone Number</p>
              <a href="tel:{{ c.phone | replace(' ', '') }}" class="text-base font-medium text-gray-900 hover:text-brand-primary">{{ c.phone }}</a>
            </div>
          </div>
          {% endif %}

          {% if c.address %}
          <div class="flex items-center gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-gray-900 text-white flex items-center justify-center">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div>
              <p class="text-xs text-gray-500 font-medium tracking-wide">Address</p>
              <p class="text-base font-medium text-gray-900">{{ c.address }}</p>
            </div>
          </div>
          {% endif %}
        </div>
      </div>

      {# ── Right column ── #}
      <div class="flex flex-col">
        <form class="flex flex-col gap-4" action="#" method="POST">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input type="text" name="name" placeholder="Your name" required
              class="w-full rounded-xl border-2 border-gray-900/70 bg-transparent px-5 py-3.5 text-base text-gray-900 placeholder-gray-500 outline-none focus:border-gray-900 transition-colors">
            <input type="tel" name="phone" placeholder="Your number"
              class="w-full rounded-xl border-2 border-gray-900/70 bg-transparent px-5 py-3.5 text-base text-gray-900 placeholder-gray-500 outline-none focus:border-gray-900 transition-colors">
          </div>
          <input type="email" name="email" placeholder="Your email" required
            class="w-full rounded-xl border-2 border-gray-900/70 bg-transparent px-5 py-3.5 text-base text-gray-900 placeholder-gray-500 outline-none focus:border-gray-900 transition-colors">
          <textarea name="message" rows="5" placeholder="{{ c.formPlaceholder | default('Let us know when you would like to visit, or simply leave your phone number and we will give you a call') }}"
            class="w-full rounded-xl border-2 border-gray-900/70 bg-transparent px-5 py-3.5 text-base text-gray-900 placeholder-gray-500 outline-none focus:border-gray-900 transition-colors resize-none"></textarea>
          <div>
            <button type="submit"
              class="mt-1 inline-block rounded-full bg-gray-900 px-8 py-3.5 text-base font-bold text-white hover:bg-gray-800 transition-colors">
              {{ c.submitLabel | default('Submit your message') }}
            </button>
          </div>
        </form>

        <div class="mt-auto pt-10">
          {% if c.socialsHeading %}
          <p class="text-base font-bold text-gray-900">{{ c.socialsHeading }}</p>
          {% endif %}

          {% if c.socials and c.socials.length %}
          <div class="mt-3 flex items-center gap-3">
            {% for s in c.socials %}
            <a href="{{ s.url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ s.platform }}"
              class="flex-shrink-0 w-10 h-10 rounded-full bg-gray-900 text-white flex items-center justify-center hover:bg-gray-800 transition-colors">
              {% if s.icon == "facebook" %}
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              {% elif s.icon == "instagram" %}
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              {% elif s.icon == "linkedin" %}
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              {% elif s.icon == "tiktok" %}
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.52a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.8a8.24 8.24 0 0 0 4.76 1.5V6.85a4.84 4.84 0 0 1-1-.16z"/></svg>
              {% endif %}
            </a>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>
