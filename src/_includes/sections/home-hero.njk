{# Dummy hero — redo later #}
<section class="section-padding" style="background: #f1f5f9;">
  <div class="container-custom">
    {% set h = home.hero if home and home.hero else {} %}
    {% if h.eyebrow %}<p style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em;">{{ h.eyebrow }}</p>{% endif %}
    <h1 style="font-size: 2rem; margin: 0.5rem 0;">{{ h.headline | default('Your headline here') }}</h1>
    <p style="font-size: 1.125rem; margin-bottom: 1rem;">{{ h.subheadline | default('Short supporting line.') }}</p>
    {% if h.ctaPrimary %}
    <a href="{{ h.ctaPrimary.url }}" style="display: inline-block; padding: 0.5rem 1rem; background: #2563eb; color: white; text-decoration: none; border-radius: 4px;">{{ h.ctaPrimary.label }}</a>
    {% endif %}
    {% if h.ctaSecondary %}
    <a href="{{ h.ctaSecondary.url }}" style="display: inline-block; padding: 0.5rem 1rem; margin-left: 0.5rem;">{{ h.ctaSecondary.label }}</a>
    {% endif %}
  </div>
</section>
